{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mam-plannings",
  "version": "1.0.0",
  "identifier": "fr.vgautier.mam-plannings",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MAM Plannings",
        "dragDropEnabled": false,
        "width": 800,
        "height": 600,
        "resizable": true,
        "maximized": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM3NDA3MDhFMzg2RDJFQ0QKUldUTkxtMDRqbkJBeDBHUUpwaWdXZW9zUHY4MXlReWNwRC9tWG1CUkR0ZFpZNFJIakVDT01FSHoK",
      "endpoints": [
        "https://github.com/vgauti/mam-plannings/releases/latest/download/latest.json"
      ]
    }
  }
}
